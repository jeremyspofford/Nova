# Nova AI Platform — environment configuration
# cp .env.example .env

# ── Infrastructure ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=nova_dev_password

# ── Model Selection ─────────────────────────────────────────────────────────
# DEFAULT_CHAT_MODEL picks which model handles requests with no explicit model.
# Set to any key in the registry (llm-gateway/app/registry.py).
DEFAULT_CHAT_MODEL=qwen2.5:1.5b

# ── Per-provider default models (optional overrides) ────────────────────────
# These swap the model a provider uses when routing to it, without changing
# which provider is used. Useful for picking a faster/cheaper tier variant.
#
# DEFAULT_OLLAMA_MODEL=llama3.2           # swap to mistral, qwen2.5, phi4, etc.
# DEFAULT_GROQ_MODEL=groq/llama-3.3-70b-versatile   # or groq/llama-3.1-8b-instant
# DEFAULT_GEMINI_MODEL=gemini/gemini-2.5-flash       # or gemini/gemini-2.5-pro
# DEFAULT_CEREBRAS_MODEL=cerebras/llama-3.3-70b      # or cerebras/llama-3.1-8b
# DEFAULT_OPENROUTER_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free
# DEFAULT_GITHUB_MODEL=github/gpt-4o-mini            # or github/meta-llama-3.1-70b-instruct
# DEFAULT_CLAUDE_MAX_MODEL=claude-max/claude-sonnet-4-6  # or claude-max/claude-opus-4-6
# DEFAULT_CHATGPT_MODEL=chatgpt/gpt-4o               # or chatgpt/o3, chatgpt/gpt-4o-mini

# ══════════════════════════════════════════════════════════════════════════════
# SUBSCRIPTION AUTH — use your existing paid subscriptions, no extra API billing
# ══════════════════════════════════════════════════════════════════════════════

# ── Claude Max / Pro subscription ───────────────────────────────────────────
# Uses your claude.ai subscription quota — NOT billed to api.anthropic.com
#
# Step 1: Authenticate (one-time): claude auth login
# Step 2: Generate a persistent token:  claude setup-token
# Step 3: Paste the sk-ant-oat01-... token below:
CLAUDE_CODE_OAUTH_TOKEN=
#
# Auto-discovery (no token needed):
#   Linux:  token read automatically from ~/.claude/.credentials.json
#   macOS:  token read automatically from macOS Keychain (if `claude auth login` was run)
#
# To use as default model: DEFAULT_CHAT_MODEL=claude-max/claude-sonnet-4-6
# Available subscription models:
#   claude-max/claude-sonnet-4-6
#   claude-max/claude-opus-4-6
#   claude-max/claude-haiku-4-5

# ── ChatGPT Plus / Pro subscription ─────────────────────────────────────────
# Uses your ChatGPT subscription quota — NOT billed to api.openai.com
#
# Step 1: Authenticate (one-time): codex login
#         Token auto-read from ~/.codex/auth.json — no manual step needed
#
# OR manually extract and paste the JWT token:
#   jq -r '.tokens.access_token' ~/.codex/auth.json
CHATGPT_ACCESS_TOKEN=
#
# Optional: override the directory where auth.json lives
# CHATGPT_TOKEN_DIR=~/.codex
#
# To use as default model: DEFAULT_CHAT_MODEL=chatgpt/gpt-4o
# Available subscription models:
#   chatgpt/gpt-4o
#   chatgpt/gpt-4o-mini
#   chatgpt/o3
#   chatgpt/o4-mini
#   chatgpt/gpt-5.3-codex

# ══════════════════════════════════════════════════════════════════════════════
# FREE TIER PROVIDERS — no credit card required, no subscription needed
# ══════════════════════════════════════════════════════════════════════════════

# Ollama is always active (local, unlimited) — no config needed.
# Models pulled by scripts/setup.sh: llama3.2, nomic-embed-text

# ── Groq — 14,400 req/day, fast Llama 3.3 70B ───────────────────────────────
# Sign up free (no CC): https://console.groq.com
GROQ_API_KEY=
# To use: DEFAULT_CHAT_MODEL=groq/llama-3.3-70b-versatile

# ── Google Gemini — 250 req/day ─────────────────────────────────────────────
# Sign up free (no CC): https://aistudio.google.com
GEMINI_API_KEY=
# To use: DEFAULT_CHAT_MODEL=gemini/gemini-2.5-flash
#
# Alt: use gcloud ADC (no API key needed, just gcloud CLI):
#   gcloud auth application-default login
#   Set GEMINI_USE_ADC=true and uncomment the volume mount in docker-compose.yml
GEMINI_USE_ADC=false

# ── Cerebras — 1M tokens/day, extremely fast ────────────────────────────────
# Sign up free (no CC): https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# To use: DEFAULT_CHAT_MODEL=cerebras/llama-3.3-70b

# ── OpenRouter — 50+ free req/day across many models ────────────────────────
# Sign up free (no CC): https://openrouter.ai
OPENROUTER_API_KEY=
# To use: DEFAULT_CHAT_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free

# ── GitHub Models — 50-150 req/day, any GitHub account ──────────────────────
# Create PAT: https://github.com/settings/tokens  (Models read permission)
GITHUB_TOKEN=
# To use: DEFAULT_CHAT_MODEL=github/gpt-4o-mini

# ══════════════════════════════════════════════════════════════════════════════
# PAID API KEYS — billed per token
# ══════════════════════════════════════════════════════════════════════════════

# Anthropic API — api.anthropic.com (separate from claude.ai subscription above)
ANTHROPIC_API_KEY=
# To use: DEFAULT_CHAT_MODEL=claude-sonnet-4-6  (routes to subscription if token set)

# OpenAI API — api.openai.com (separate from ChatGPT subscription above)
OPENAI_API_KEY=
# To use: DEFAULT_CHAT_MODEL=gpt-4o

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Phase 2: Auth + Cost Tracking ───────────────────────────────────────────
NOVA_ADMIN_SECRET=nova-admin-secret-change-me
REQUIRE_AUTH=false

# ── Phase 3: Workspace / Shell ───────────────────────────────────────────────
# Set to your project root — agents will read/write files here.
# NOVA_WORKSPACE=/Users/you/my-project
SHELL_TIMEOUT_SECONDS=30
