#!/usr/bin/env bash
# Nova AI Platform — Uninstall Script
# Removes everything Nova installed on this machine: containers, networks,
# named volumes, locally-built Nova images, bind-mounted data, .env files,
# build artifacts, and ~/.nova/workspace/. The cloned repo source itself
# is preserved (delete it manually with `cd .. && rm -rf <repo>` if you want).
#
# Compatible with bash 3.2+ (macOS default). No associative arrays.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${SCRIPT_DIR}"

# ── Colors (only when stdout is a TTY) ────────────────────────────────────────
if [ -t 1 ]; then
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[0;33m'
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
else
  RED=""; GREEN=""; YELLOW=""; BOLD=""; DIM=""; RESET=""
fi

# ── Flags ─────────────────────────────────────────────────────────────────────
DRY_RUN=false
ASSUME_YES=false
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --yes|-y)  ASSUME_YES=true ;;
    --help|-h|-help)
      cat <<USAGE
Usage: ./uninstall [--dry-run] [--yes]

Removes Nova from this machine:
  • Stops and removes all Nova containers + networks
  • Removes Nova-managed Docker volumes
  • Removes locally-built Nova images (preserves shared upstream images
    like ollama/ollama, pgvector/pgvector, redis — these may be in use
    by other Docker projects)
  • Deletes .env, .env.backup-*, data/, backups/, build artifacts
  • Deletes ~/.nova/workspace/

The cloned repo source is kept. To delete it:  cd .. && rm -rf <repo>

Options:
  --dry-run   Show what would be removed and exit (no destruction)
  --yes, -y   Skip the 'type uninstall to confirm' prompt
USAGE
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      echo "Run with --help for usage." >&2
      exit 2
      ;;
  esac
done

# ── Helpers (portable du/stat) ────────────────────────────────────────────────
# Returns size in bytes for a file or directory. Silent (echoes 0) if missing.
path_bytes() {
  local p="$1"
  if [ -d "$p" ]; then
    # du -sk works on both GNU and BSD; multiply by 1024 for bytes
    local kb
    kb=$(du -sk "$p" 2>/dev/null | awk '{print $1}')
    echo $(( ${kb:-0} * 1024 ))
  elif [ -f "$p" ]; then
    # stat: GNU first, BSD fallback
    stat -c '%s' "$p" 2>/dev/null || stat -f '%z' "$p" 2>/dev/null || echo 0
  else
    echo 0
  fi
}

# Human-readable size from bytes
human_size() {
  local b=$1
  if   [ "$b" -lt 1024 ];          then echo "${b}B"
  elif [ "$b" -lt 1048576 ];       then echo "$((b/1024))KB"
  elif [ "$b" -lt 1073741824 ];    then echo "$((b/1048576))MB"
  else echo "$((b/1073741824))GB"
  fi
}

# Print a line only if its first arg is a non-empty list
maybe_list() {
  local heading="$1"; shift
  local val="$1"
  if [ -n "$val" ]; then
    echo "  $heading"
    echo "$val" | sed 's/^/    /'
  fi
}

# ── Discovery ─────────────────────────────────────────────────────────────────
have_docker=true
if ! command -v docker >/dev/null 2>&1 || ! docker info >/dev/null 2>&1; then
  have_docker=false
fi

NOVA_CONTAINERS=""; NOVA_NETWORKS=""; NOVA_VOLUMES=""; NOVA_IMAGES=""
if [ "$have_docker" = "true" ]; then
  # Docker's --filter name=X is substring match; we want strict prefix to avoid
  # claiming resources from other projects that happen to have "nova" in their
  # names (e.g. infra_nova_db). Use grep '^nova[-_]' to enforce prefix.
  NOVA_CONTAINERS=$(docker ps -a --format "{{.Names}}" 2>/dev/null | grep '^nova-' | sort || true)
  NOVA_NETWORKS=$(docker network ls --format "{{.Name}}" 2>/dev/null | grep '^nova_' || true)
  NOVA_VOLUMES=$(docker volume ls --format "{{.Name}}" 2>/dev/null | grep '^nova_' || true)
  # Locally-built Nova images: repository starts with "nova-"
  NOVA_IMAGES=$(docker images --format "{{.Repository}}:{{.Tag}} {{.Size}}" 2>/dev/null | grep '^nova-' || true)
fi

# Resolve NOVA_WORKSPACE from .env, default to ~/.nova/workspace
NOVA_WORKSPACE_PATH=""
if [ -f "${PROJECT_ROOT}/.env" ]; then
  NOVA_WORKSPACE_PATH=$(grep '^NOVA_WORKSPACE=' "${PROJECT_ROOT}/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' | tr -d "'")
fi
NOVA_WORKSPACE_PATH=${NOVA_WORKSPACE_PATH:-"${HOME}/.nova/workspace"}
# Expand leading ~
case "$NOVA_WORKSPACE_PATH" in
  '~/'*) NOVA_WORKSPACE_PATH="${HOME}/${NOVA_WORKSPACE_PATH#~/}" ;;
  '~')   NOVA_WORKSPACE_PATH="${HOME}" ;;
esac

# Build the path list (parallel arrays for bash 3.2)
PATH_LIST=""
PATH_DESCS=""
add_path() {
  local p="$1" desc="$2"
  if [ -e "$p" ]; then
    PATH_LIST="${PATH_LIST}${p}"$'\n'
    PATH_DESCS="${PATH_DESCS}${desc}"$'\n'
  fi
}

add_path "${PROJECT_ROOT}/.env" "secrets file"
# .env.backup-* (use ls glob expansion safely)
for b in "${PROJECT_ROOT}/.env.backup-"*; do
  [ -f "$b" ] && add_path "$b" "env backup"
done
add_path "${PROJECT_ROOT}/data" "bind-mounted postgres/redis/sources"
add_path "${PROJECT_ROOT}/backups" "database dumps"
add_path "${PROJECT_ROOT}/dist" "build output"
add_path "${PROJECT_ROOT}/website/dist" "website build output"
add_path "${PROJECT_ROOT}/dashboard/dist" "dashboard build output"
add_path "${PROJECT_ROOT}/dashboard/node_modules" "node_modules"
add_path "${PROJECT_ROOT}/website/node_modules" "node_modules"
add_path "${NOVA_WORKSPACE_PATH}" "agent workspace"

# Python caches inside repo (separate so the preview can summarize as a count)
PYCACHE_LIST=""
PYCACHE_COUNT=0
if [ -d "${PROJECT_ROOT}" ]; then
  PYCACHE_LIST=$(find "${PROJECT_ROOT}" -type d \( -name __pycache__ -o -name .pytest_cache \) 2>/dev/null | head -500)
  if [ -n "$PYCACHE_LIST" ]; then
    PYCACHE_COUNT=$(echo "$PYCACHE_LIST" | wc -l | awk '{print $1}')
  fi
fi

# ── Preview ───────────────────────────────────────────────────────────────────
echo "${BOLD}Nova will be uninstalled. The following will be removed:${RESET}"
echo

# Docker section
if [ "$have_docker" = "true" ]; then
  echo "${BOLD}Docker resources${RESET}"
  if [ -n "$NOVA_CONTAINERS" ]; then
    container_count=$(echo "$NOVA_CONTAINERS" | wc -l | awk '{print $1}')
    echo "  Containers (${container_count}):"
    echo "$NOVA_CONTAINERS" | sed 's/^/    /'
  else
    echo "  Containers: ${DIM}(none)${RESET}"
  fi
  maybe_list "Networks:" "$NOVA_NETWORKS"
  maybe_list "Named volumes:" "$NOVA_VOLUMES"
  if [ -n "$NOVA_IMAGES" ]; then
    echo "  Locally-built Nova images (rebuilt on next install):"
    echo "$NOVA_IMAGES" | sed 's/^/    /'
  fi
else
  echo "${BOLD}Docker resources${RESET}"
  echo "  ${YELLOW}Docker not available — skipping Docker cleanup.${RESET}"
fi

echo
echo "${BOLD}Files & directories${RESET}"
total_bytes=0
i=1
echo "$PATH_LIST" | while IFS= read -r p; do
  [ -z "$p" ] && continue
  desc=$(echo "$PATH_DESCS" | sed -n "${i}p")
  bytes=$(path_bytes "$p")
  printf "  %-60s %10s  ${DIM}%s${RESET}\n" "$p" "$(human_size $bytes)" "$desc"
  i=$((i+1))
done

# Recompute total in main shell for the summary (the `while` ran in a subshell)
total_bytes=0
i=1
while IFS= read -r p; do
  [ -z "$p" ] && continue
  bytes=$(path_bytes "$p")
  total_bytes=$((total_bytes + bytes))
  i=$((i+1))
done <<EOF
$PATH_LIST
EOF

if [ "$PYCACHE_COUNT" -gt 0 ]; then
  echo "  ${DIM}(${PYCACHE_COUNT} __pycache__ / .pytest_cache directories inside repo)${RESET}"
fi
echo
echo "  ${BOLD}Filesystem reclaim: ~$(human_size $total_bytes)${RESET}"

# What we keep
echo
echo "${BOLD}NOT removed (kept intact)${RESET}"
echo "  ${GREEN}✓${RESET} The cloned repo source files (this directory)"
echo "  ${GREEN}✓${RESET} Shared upstream Docker images (ollama/ollama, pgvector/pgvector, redis, etc.)"
echo "  ${GREEN}✓${RESET} Docker build cache"
echo
echo "  ${DIM}To delete the repo too:           cd .. && rm -rf $(basename "${PROJECT_ROOT}")${RESET}"
echo "  ${DIM}To remove shared upstream images: docker image prune -a${RESET}"
echo "  ${DIM}To clear Docker build cache:      docker builder prune${RESET}"
echo

if [ "$DRY_RUN" = "true" ]; then
  echo "${YELLOW}--dry-run: nothing was removed.${RESET}"
  exit 0
fi

# ── Confirm ───────────────────────────────────────────────────────────────────
if [ "$ASSUME_YES" != "true" ]; then
  printf "Type ${BOLD}uninstall${RESET} to confirm: "
  read -r confirm
  if [ "$confirm" != "uninstall" ]; then
    echo "${RED}Aborted.${RESET}"
    exit 1
  fi
fi

# ── Execute ───────────────────────────────────────────────────────────────────
echo
echo "${BOLD}Uninstalling...${RESET}"

if [ "$have_docker" = "true" ]; then
  # Stop services via compose first (with all profiles active so nothing is missed).
  if [ -n "$NOVA_CONTAINERS" ] || [ -n "$NOVA_VOLUMES" ]; then
    echo "  Stopping Nova services..."
    cd "${PROJECT_ROOT}"
    COMPOSE_PROFILES="bridges,knowledge,voice,local-ollama,local-vllm,local-sglang,editor-vscode,editor-neovim,website,cloudflare-tunnel,tailscale,benchmark,secrets" \
      docker compose down --remove-orphans 2>&1 | tail -5 | sed 's/^/    /'
  fi

  # Belt-and-suspenders: nuke any leftover nova-* containers compose might have missed.
  if [ -n "$NOVA_CONTAINERS" ]; then
    echo "  Removing leftover containers..."
    echo "$NOVA_CONTAINERS" | while IFS= read -r c; do
      [ -n "$c" ] && docker rm -f "$c" >/dev/null 2>&1 || true
    done
  fi

  # Networks (compose usually removes these on `down`, but cover stragglers).
  if [ -n "$NOVA_NETWORKS" ]; then
    echo "$NOVA_NETWORKS" | while IFS= read -r n; do
      [ -n "$n" ] && docker network rm "$n" >/dev/null 2>&1 || true
    done
  fi

  # Named volumes
  if [ -n "$NOVA_VOLUMES" ]; then
    echo "  Removing named volumes..."
    echo "$NOVA_VOLUMES" | while IFS= read -r v; do
      [ -n "$v" ] && docker volume rm "$v" >/dev/null 2>&1 || true
    done
  fi

  # Locally-built Nova images
  if [ -n "$NOVA_IMAGES" ]; then
    echo "  Removing locally-built Nova images..."
    echo "$NOVA_IMAGES" | awk '{print $1}' | while IFS= read -r img; do
      [ -n "$img" ] && docker rmi "$img" >/dev/null 2>&1 || true
    done
  fi
fi

# Filesystem cleanup
if [ -n "$PATH_LIST" ]; then
  echo "  Removing files and directories..."
  echo "$PATH_LIST" | while IFS= read -r p; do
    [ -z "$p" ] && continue
    rm -rf "$p" 2>/dev/null || true
  done
fi

# Python caches
if [ -n "$PYCACHE_LIST" ]; then
  echo "  Removing Python caches..."
  echo "$PYCACHE_LIST" | while IFS= read -r p; do
    [ -z "$p" ] && continue
    rm -rf "$p" 2>/dev/null || true
  done
fi

echo
echo "${GREEN}${BOLD}✓ Nova has been uninstalled.${RESET}"
echo
echo "  To delete the repo source: ${BOLD}cd .. && rm -rf $(basename "${PROJECT_ROOT}")${RESET}"
echo
