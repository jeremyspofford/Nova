#!/usr/bin/env bash
set -euo pipefail

# Nova — Local Development
# Usage: ./dev

# --- Prerequisites ---
missing=()
command -v docker >/dev/null 2>&1 || missing+=("docker  — https://docs.docker.com/get-docker/")
docker compose version >/dev/null 2>&1 || missing+=("docker compose plugin — https://docs.docker.com/compose/install/")
command -v make   >/dev/null 2>&1 || missing+=("make    — apt install make / brew install make")
command -v node   >/dev/null 2>&1 || missing+=("node    — https://nodejs.org/")

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "Missing required tools:"
  printf "  • %s\n" "${missing[@]}"
  exit 1
fi

# First-time setup: run setup.sh if .env doesn't exist
if [[ ! -f .env ]]; then
  echo "No .env found — running first-time setup..."
  ./scripts/setup.sh
fi

# Install dashboard deps if needed
if [[ ! -d dashboard/node_modules ]]; then
  echo "Installing dashboard dependencies..."
  (cd dashboard && npm install)
fi

# --- Start dev environment ---
# Backend services (Docker) + Vite dashboard with hot-reload
make dev "$@"
