# Copy to infra/.env and adjust for your environment
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova
POSTGRES_DB=nova
DATABASE_URL=postgresql://nova:nova@db:5432/nova
DEPLOYMENT_MODE=local

# LLM Provider (optional — no local provider seeded if absent)
# On Linux/WSL2: set OLLAMA_HOST=0.0.0.0:11434 on Windows so Ollama binds to
# all interfaces, set DOCKER_HOST_IP to your machine's LAN IP, and use
# http://host.docker.internal:11434 here.
OLLAMA_BASE_URL=http://host.docker.internal:11434
DOCKER_HOST_IP=192.168.0.x
OLLAMA_MODEL=gemma3:4b

# Home Assistant (optional — ha.light.turn_on returns error if absent)
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=REPLACE_WITH_YOUR_HA_TOKEN

# Nova-lite
NOVA_API_URL=http://api:8000
LOOP_INTERVAL_SECONDS=15
LOG_LEVEL=INFO
