# Copy to infra/.env and adjust for your environment
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova
POSTGRES_DB=nova
DATABASE_URL=postgresql://nova:nova@db:5432/nova
DEPLOYMENT_MODE=local

# LLM Provider (optional — no local provider seeded if absent)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b

# Home Assistant (optional — ha.light.turn_on returns error if absent)
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=REPLACE_WITH_YOUR_HA_TOKEN
