---
import Landing from '../layouts/Landing.astro';
import Footer from '../components/Footer.astro';
---

<Landing title="Aria Labs -- Software That Ships" description="AI tools, civic tech, and productivity software. Engineering-first, shipped to production.">
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-stone-800/40 bg-[#0a0a0b]/80 backdrop-blur-xl">
    <div class="flex items-center justify-between px-6 py-3.5 max-w-7xl mx-auto">
      <a href="/" class="text-base font-bold text-white tracking-tight">Aria Labs</a>
      <div class="flex items-center gap-8">
        <a href="/nova/" class="text-xs text-stone-500 hover:text-stone-200 transition-colors tracking-wide">Nova</a>
        <a href="/nova/docs/quickstart/" class="text-xs text-stone-500 hover:text-stone-200 transition-colors tracking-wide">Docs</a>
        <a href="https://github.com/arialabs" target="_blank" rel="noopener noreferrer" class="text-xs text-stone-500 hover:text-stone-200 transition-colors tracking-wide">GitHub</a>
      </div>
    </div>
  </nav>

  <div class="h-12" />

  <!-- Hero -->
  <section class="relative px-6 py-28 sm:py-36 overflow-hidden">
    <!-- Background glow -->
    <div class="absolute top-0 left-1/3 w-[560px] h-[420px] rounded-full pointer-events-none" style="background: rgba(20, 184, 166, 0.06); filter: blur(120px);" />
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] rounded-full pointer-events-none" style="background: rgba(37, 99, 235, 0.04); filter: blur(100px);" />

    <div class="relative max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-stone-800 bg-stone-900/50 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" />
        <span class="text-xs text-stone-500 tracking-wide font-mono">dev tools &middot; civic tech &middot; AI infrastructure</span>
      </div>

      <h1 class="text-5xl sm:text-7xl font-bold text-white tracking-tight leading-[1.05]">
        We build tools<br/>that actually <span class="text-teal-400">ship.</span>
      </h1>

      <p class="mt-6 text-lg text-stone-500 max-w-xl mx-auto leading-relaxed">
        From autonomous AI platforms to civic tech and productivity apps —
        Aria Labs engineers software that solves real problems and deploys to production.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/nova/" class="inline-flex items-center gap-2 px-6 py-3 bg-teal-600 hover:bg-teal-500 text-white font-medium text-sm rounded-lg transition-colors">
          Explore Nova
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" /></svg>
        </a>
        <a href="https://github.com/arialabs" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 border border-stone-700 hover:border-stone-500 text-stone-400 hover:text-white font-medium text-sm rounded-lg transition-all">
          GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-5xl px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-stone-800/60 to-transparent" />
  </div>

  <!-- Flagship: Nova -->
  <section class="relative px-6 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="text-xs font-semibold text-teal-400 uppercase tracking-[0.2em] mb-3">Flagship Product</p>
        <h2 class="text-3xl font-bold text-white tracking-tight sm:text-4xl">Nova</h2>
        <p class="mt-4 text-stone-500 max-w-2xl mx-auto">
          A self-directed autonomous AI platform. Define a goal — Nova breaks it into subtasks,
          executes them through a coordinated agent pipeline, and completes the work.
          Self-hosted, private, extensible.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { title: 'Persistent Memory', desc: 'Semantic, episodic, and procedural memory with hybrid retrieval. Nova remembers across sessions.' },
          { title: 'Agent Pipeline', desc: '5-stage Quartet pipeline with guardrails and code review on every task. Safety built in.' },
          { title: '9 LLM Providers', desc: 'Route to Anthropic, OpenAI, Ollama, Groq, Gemini, and more. Cloud or local, your choice.' },
          { title: 'Full Dashboard', desc: 'Real-time admin UI for chat, tasks, models, memory, MCP tools, and settings.' },
        ].map((f) => (
          <div class="rounded-xl border border-stone-800/60 bg-stone-900/30 p-5 hover:border-teal-800/40 transition-colors">
            <h3 class="text-sm font-semibold text-stone-200 mb-2">{f.title}</h3>
            <p class="text-xs text-stone-500 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="/nova/" class="text-sm font-medium text-teal-400 hover:text-teal-300 transition-colors">
          Learn more about Nova &rarr;
        </a>
        <a href="/nova/docs/quickstart/" class="text-sm font-medium text-stone-500 hover:text-stone-300 transition-colors">
          Quick Start
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-5xl px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-stone-800/60 to-transparent" />
  </div>

  <!-- Other Projects -->
  <section class="relative px-6 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="text-xs font-semibold text-emerald-400 uppercase tracking-[0.2em] mb-3">Our Work</p>
        <h2 class="text-3xl font-bold text-white tracking-tight sm:text-4xl">What We're Building</h2>
        <p class="mt-4 text-stone-500 max-w-lg mx-auto">
          Each project tackles something we needed ourselves.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <a href="https://reps.arialabs.ai" target="_blank" rel="noopener noreferrer"
          class="group rounded-xl overflow-hidden border border-stone-800/40 hover:border-stone-700/60 transition-all p-6"
          style="background: linear-gradient(135deg, #374151, #111827);">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[11px] text-stone-500 uppercase tracking-widest font-mono">Civic Tech</span>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" />
              <span class="text-xs text-stone-500 font-mono">Live</span>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Rep Accountability</h3>
          <p class="text-sm text-stone-400 leading-relaxed mb-4">
            Track how politicians vote compared to their donor interests.
            Follow the money, expose conflicts, hold leadership accountable.
          </p>
          <span class="text-xs text-stone-600 font-mono">535 representatives tracked</span>
        </a>

        <a href="https://jobhunter.arialabs.ai" target="_blank" rel="noopener noreferrer"
          class="group rounded-xl overflow-hidden border border-stone-800/40 hover:border-stone-700/60 transition-all p-6"
          style="background: linear-gradient(135deg, #1e3a5f, #0f172a);">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[11px] text-stone-500 uppercase tracking-widest font-mono">Career Tech</span>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" />
              <span class="text-xs text-stone-500 font-mono">Live</span>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">JobHunter</h3>
          <p class="text-sm text-stone-400 leading-relaxed mb-4">
            AI-powered job search that discovers, matches, and tracks opportunities
            across multiple sources. BYOK support.
          </p>
          <span class="text-xs text-stone-600 font-mono">AI job matching</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-5xl px-6">
    <div class="h-px bg-gradient-to-r from-transparent via-stone-800/60 to-transparent" />
  </div>

  <!-- Stats -->
  <section class="relative px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: 'Open', label: 'Source' },
          { value: '535', label: 'Reps Tracked' },
          { value: '9+', label: 'LLM Providers' },
          { value: '2026', label: 'Founded' },
        ].map((s) => (
          <div>
            <div class="text-3xl font-bold text-white">{s.value}</div>
            <div class="mt-1 text-[11px] text-stone-600 uppercase tracking-widest font-mono">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Landing>
