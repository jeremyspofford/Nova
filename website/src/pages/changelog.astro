---
import Landing from '../layouts/Landing.astro';
import Footer from '../components/Footer.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('changelog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Landing title="Changelog — Nova" description="What's new in Nova.">
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-stone-800/40 bg-[#0a0a0b]/80 backdrop-blur-xl">
    <div class="flex items-center justify-between px-6 py-3.5 max-w-7xl mx-auto">
      <a href="/" class="text-base font-bold text-white tracking-tight">Nova</a>
      <div class="flex items-center gap-8">
        <a href="/quickstart/" class="text-xs text-stone-500 hover:text-stone-200 transition-colors tracking-wide">Docs</a>
        <a href="/changelog/" class="text-xs text-teal-400 transition-colors tracking-wide">Changelog</a>
        <a href="https://github.com/arialabs/nova" target="_blank" rel="noopener noreferrer" class="text-xs text-stone-500 hover:text-stone-200 transition-colors tracking-wide">GitHub</a>
      </div>
    </div>
  </nav>

  <div class="h-12" />

  <main class="px-6 py-20 max-w-3xl mx-auto">
    <div class="mb-12">
      <p class="text-xs font-semibold text-teal-400 uppercase tracking-[0.2em] mb-3">Updates</p>
      <h1 class="text-3xl font-bold text-white tracking-tight sm:text-4xl">Changelog</h1>
      <p class="mt-4 text-stone-500">What's new in Nova.</p>
    </div>

    <div class="space-y-12">
      {await Promise.all(entries.map(async (entry, i) => {
        const { Content } = await render(entry);
        return (
          <article class="relative pl-8 border-l border-stone-800/60" style={`animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: ${i * 80}ms;`}>
            <div class="absolute left-0 top-1 w-2 h-2 rounded-full bg-teal-500 -translate-x-[4.5px]" />
            <time class="text-[11px] font-medium text-stone-600 uppercase tracking-wider">
              {new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="text-lg font-semibold text-stone-200 mt-1 tracking-tight">{entry.data.title}</h2>
            <div class="mt-3 text-sm text-stone-500 leading-relaxed [&_ul]:list-none [&_ul]:pl-0 [&_li]:relative [&_li]:pl-4 [&_li]:before:content-[''] [&_li]:before:absolute [&_li]:before:left-0 [&_li]:before:top-[10px] [&_li]:before:w-1.5 [&_li]:before:h-px [&_li]:before:bg-stone-700 [&_li]:py-0.5">
              <Content />
            </div>
          </article>
        );
      }))}
    </div>
  </main>

  <Footer />
</Landing>
