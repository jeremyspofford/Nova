---
interface Props {
  title: string;
  description: string;
  accent?: 'teal' | 'emerald' | 'amber' | 'rose';
  large?: boolean;
}

const { title, description, accent = 'teal', large = false } = Astro.props;

const accentColors = {
  teal: 'from-teal-500/10 to-transparent',
  emerald: 'from-emerald-500/10 to-transparent',
  amber: 'from-amber-500/10 to-transparent',
  rose: 'from-rose-500/10 to-transparent',
};

const dotColors = {
  teal: 'bg-teal-500',
  emerald: 'bg-emerald-500',
  amber: 'bg-amber-500',
  rose: 'bg-rose-500',
};
---

<div class:list={[
  'feature-card group rounded-xl border border-stone-800/80 bg-stone-900/30 backdrop-blur-sm transition-all duration-300 cursor-default',
  large ? 'p-8' : 'p-6',
]}>
  <div class="flex items-start gap-3">
    <div class:list={['mt-1.5 w-1.5 h-1.5 rounded-full shrink-0', dotColors[accent]]} />
    <div>
      <h3 class:list={[
        'font-semibold text-stone-100 tracking-tight',
        large ? 'text-lg' : 'text-[15px]',
      ]}>{title}</h3>
      <p class:list={[
        'mt-2 leading-relaxed text-stone-500 group-hover:text-stone-400 transition-colors duration-300',
        large ? 'text-sm' : 'text-[13px]',
      ]}>{description}</p>
    </div>
  </div>
</div>
