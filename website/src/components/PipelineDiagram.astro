---
const stages = [
  { name: 'Context Agent', description: 'Curates relevant code, docs, and task history', color: 'teal', dotClass: 'bg-teal-500', textClass: 'text-teal-400', lineClass: 'from-teal-500/50' },
  { name: 'Task Agent', description: 'Produces the actual output — code, config, or answer', color: 'emerald', dotClass: 'bg-emerald-500', textClass: 'text-emerald-400', lineClass: 'from-emerald-500/50' },
  { name: 'Guardrail Agent', description: 'Checks for prompt injection, PII, credential leaks, spec drift', color: 'amber', dotClass: 'bg-amber-500', textClass: 'text-amber-400', lineClass: 'from-amber-500/50' },
  { name: 'Code Review', description: 'Pass, needs refactor, or reject — loops back up to 3 times', color: 'teal', dotClass: 'bg-teal-500', textClass: 'text-teal-400', lineClass: 'from-teal-500/50' },
  { name: 'Decision Agent', description: 'Creates decision record and escalates to human on rejection', color: 'rose', dotClass: 'bg-rose-500', textClass: 'text-rose-400', lineClass: 'from-rose-500/50' },
];

const postPipeline = ['Documentation', 'Diagramming', 'Security Review', 'Memory Extraction'];
---

<section class="relative px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-xs font-semibold text-teal-400 uppercase tracking-[0.2em] mb-3">Agent Pipeline</p>
      <h2 class="text-3xl font-bold text-white tracking-tight sm:text-4xl">Five Agents. One Pipeline.</h2>
      <p class="mt-4 text-stone-500 max-w-xl mx-auto">
        Every task runs through specialized agents with built-in safety rails. No shortcuts.
      </p>
    </div>

    <!-- Pipeline visualization -->
    <div class="relative max-w-2xl mx-auto">
      {stages.map((stage, i) => (
        <div class="flex items-start gap-5 relative" style={`animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: ${i * 120}ms;`}>
          <!-- Vertical connector -->
          <div class="flex flex-col items-center w-6 shrink-0">
            <!-- Node -->
            <div class="relative z-10">
              <div class:list={['w-3 h-3 rounded-full', stage.dotClass]} />
              <div class:list={['absolute inset-0 rounded-full animate-ping opacity-20', stage.dotClass]} style={`animation-duration: ${3 + i * 0.5}s;`} />
            </div>
            <!-- Line to next node -->
            {i < stages.length - 1 && (
              <div class="w-px h-16 mt-1 bg-gradient-to-b from-stone-700 to-transparent" />
            )}
          </div>

          <!-- Content -->
          <div class="pb-12">
            <div class="flex items-center gap-2.5">
              <span class:list={['text-sm font-semibold tracking-tight', stage.textClass]}>{stage.name}</span>
              {stage.name === 'Code Review' && (
                <span class="text-[10px] font-medium text-stone-600 border border-stone-800 rounded px-1.5 py-0.5">loops 3x</span>
              )}
            </div>
            <p class="text-sm text-stone-500 mt-1 leading-relaxed">{stage.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Post-pipeline -->
    <div class="max-w-2xl mx-auto mt-4 rounded-xl border border-stone-800/60 bg-stone-900/20 p-5">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-4 h-px bg-stone-700" />
        <p class="text-[10px] font-semibold text-stone-600 uppercase tracking-[0.15em]">Post-Pipeline</p>
        <div class="flex-1 h-px bg-stone-800/60" />
        <span class="text-[10px] text-stone-700">parallel, non-blocking</span>
      </div>
      <div class="flex flex-wrap gap-2">
        {postPipeline.map((agent) => (
          <span class="text-xs rounded-md border border-stone-800/60 bg-stone-900/40 px-3 py-1.5 text-stone-500 font-medium">{agent}</span>
        ))}
      </div>
    </div>
  </div>
</section>
