---
const lines = [
  { prompt: '~', command: 'git clone https://github.com/arialabs/nova.git' },
  { prompt: '~', command: 'cd nova' },
  { prompt: '~/nova', command: './setup' },
];
---

<section id="install" class="relative px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-3xl">
    <!-- Section header -->
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-teal-400 uppercase tracking-[0.2em] mb-3">Get Started</p>
      <h2 class="text-3xl font-bold text-white tracking-tight sm:text-4xl">Three commands. That's it.</h2>
      <p class="mt-4 text-stone-500 max-w-lg mx-auto">
        The setup wizard detects your hardware, configures providers, and starts everything.
      </p>
    </div>

    <!-- Terminal window -->
    <div class="terminal-window rounded-xl border border-stone-800/80 bg-[#0e0e10] overflow-hidden shadow-2xl shadow-black/40">
      <!-- Title bar -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-stone-800/60 bg-stone-900/30">
        <div class="flex gap-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-stone-700/80" />
          <div class="w-2.5 h-2.5 rounded-full bg-stone-700/80" />
          <div class="w-2.5 h-2.5 rounded-full bg-stone-700/80" />
        </div>
        <span class="text-[11px] text-stone-600 font-medium ml-2" style="font-family: 'JetBrains Mono', monospace;">terminal</span>
      </div>

      <!-- Command lines -->
      <div class="p-5 space-y-2" style="font-family: 'JetBrains Mono', monospace;">
        {lines.map((line, i) => (
          <div class="flex items-center gap-0 text-sm" style={`animation: fade-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: ${i * 150 + 200}ms;`}>
            <span class="text-stone-600 select-none shrink-0">{line.prompt}</span>
            <span class="text-teal-500/60 select-none mx-1">$</span>
            <span class="text-stone-300">{line.command}</span>
          </div>
        ))}
        <div class="flex items-center gap-0 text-sm mt-4" style="animation: fade-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 800ms;">
          <span class="text-emerald-500/80 text-xs">✓</span>
          <span class="text-stone-600 text-xs ml-2">Nova is running at http://localhost:3001</span>
        </div>
      </div>
    </div>

    <!-- Remote GPU callout -->
    <div class="mt-6 flex items-start gap-4 rounded-xl border border-stone-800/40 bg-stone-900/15 p-5">
      <div class="shrink-0 mt-0.5">
        <svg class="w-4 h-4 text-amber-500/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-stone-300">Remote GPU</p>
        <p class="text-[13px] text-stone-500 mt-1 leading-relaxed">
          Got a separate machine with a GPU? Run the remote setup script on it, then re-run
          <code class="text-teal-400/80 bg-teal-900/15 px-1.5 py-0.5 rounded text-xs font-medium" style="font-family: 'JetBrains Mono', monospace;">./setup</code>
          and choose "Remote GPU".
        </p>
        <a href="/deployment/" class="inline-flex items-center gap-1 text-[13px] text-teal-400/80 hover:text-teal-300 mt-2 transition-colors">
          Deployment guide
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
