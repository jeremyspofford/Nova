{
  "mcpServers": {
    "docker": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-docker"]
    },
    "github": {
      "command": "bash",
      "args": [
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token 2>/dev/null) exec npx -y @modelcontextprotocol/server-github"
      ]
    },
    "postgres": {
      "command": "bash",
      "args": [
        "-c",
        "set -a && source .env 2>/dev/null && set +a && exec npx -y @anthropic-ai/mcp-server-postgres \"postgresql://nova:${POSTGRES_PASSWORD:-nova_dev_password}@localhost:5432/nova\""
      ]
    },
    "redis": {
      "command": "bash",
      "args": [
        "-c",
        "set -a && source .env 2>/dev/null && set +a && exec npx -y @modelcontextprotocol/server-redis \"redis://localhost:6379\""
      ]
    }
  }
}
